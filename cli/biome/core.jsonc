{
	"extends": ["ultracite/biome/core"],
	"linter": {
		"rules": {
			"suspicious": {
				// House style (maintainer decision): the array-index-key rule forced
				// key-const gymnastics on custom-component JSX where biome can't even
				// anchor a suppression comment. For AI-written code its value doesn't
				// pay its cost, so dobby consumers get it off by default.
				"noArrayIndexKey": "off"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			// Common ignores for every dobby consumer: Claude Code's dir (worktrees
			// live under .claude/worktrees — scanning them would double-lint every
			// file), dobby's own runtime state, CI config, and markdown.
			"!.claude",
			"!.dobby",
			"!.github",
			"!**/*.md"
		]
	}
}
